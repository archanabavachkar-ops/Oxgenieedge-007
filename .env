PORT=3001
CORS_ORIGIN=*
POCKETBASE_URL=http://localhost:8090
POCKETBASE_ADMIN_EMAIL=admin@example.com
POCKETBASE_ADMIN_PASSWORD=admin123456
RAZORPAY_KEY_ID=
RAZORPAY_SECRET=
STRIPE_SECRET_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=
EMAIL_SERVICE_KEY=
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
API_BASE_URL=https://oxgenieedge.com


Telephony Configuration

TELEPHONY_PROVIDER=exotel


Exotel Credentials (optional - for Exotel provider)

EXOTEL_ENABLED=true
EXOTEL_API_KEY=your_exotel_api_key
EXOTEL_API_TOKEN=your_exotel_api_token
EXOTEL_SID=your_exotel_sid
VIRTUAL_NUMBER=+91XXXXXXXXXX
CALLER_ID=your_caller_id


Twilio Credentials (optional - for Twilio provider)

TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890


Webhook Configuration

WEBHOOK_SECRET=your_webhook_secret


Google Speech-to-Text API Key (for transcription)

GOOGLE_SPEECH_API_KEY=


Recording Encryption Key (32 bytes for AES-256)

RECORDING_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef


Recording Configuration

Directory where encrypted recordings are stored (default: ./recordings)

RECORDING_STORAGE_DIR=./recordings


Number of days to retain recordings before automatic deletion (default: 90)

RECORDING_RETENTION_DAYS=90


Transcription Configuration

Language code for transcription service (default: en-US)

Examples: en-US, en-GB, es-ES, fr-FR, de-DE, hi-IN

TRANSCRIPTION_LANGUAGE=en-US


OpenAI Configuration (for AI summaries)

OpenAI API key for generating call summaries and insights

OPENAI_API_KEY=


OpenAI model to use for summaries (default: gpt-3.5-turbo)

Options: gpt-3.5-turbo, gpt-4, gpt-4-turbo-preview

OPENAI_MODEL=gpt-3.5-turbo


Compliance Configuration

Enable/disable compliance checking for recording consent (default: true)

COMPLIANCE_ENABLED=true


Number of days before recording consent expires (default: 365)

CONSENT_EXPIRY_DAYS=365


NODE_ENV=development
API_TOKEN=your-secret-api-token-here


SMTP Configuration for Email Service

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=notifications@oxgenieedge.com
SMTP_PASS=your_password_here
SMTP_FROM=OxGenie Edge notifications@oxgenieedge.com
SALES_EMAIL=hello@oxgenieedge.com