
# Railway Deployment Environment Variables Template
# Copy this file to .env and fill in your actual values

# Node Environment
NODE_ENV=production

# Server Port
PORT=3001

# PocketBase Configuration
POCKETBASE_URL=http://127.0.0.1:8090

# CORS Configuration
CORS_ORIGIN=https://oxgenieedge.com

# Logging Level
LOG_LEVEL=info
